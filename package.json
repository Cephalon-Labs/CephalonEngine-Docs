{
  "name": "cephalonengine-docs",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "clean": "node ./scripts/clean.mjs",
    "clean:build": "npm run clean && npm run build",
    "sync-docs": "node ./scripts/sync-docs.mjs",
    "check-links": "node ./scripts/check-links.mjs",
    "check-built-links": "node ./scripts/check-built-links.mjs",
    "test": "vitest run",
    "test:source": "vitest run tests/links.test.mjs tests/frontmatter.test.mjs tests/mdx-conventions.test.mjs",
    "test:built": "vitest run tests/built-links.test.mjs tests/build-output.test.mjs tests/performance.test.mjs",
    "test:watch": "vitest",
    "docker:build": "docker build -t cephalonengine-docs .",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/starlight": "^0.39.2",
    "@expressive-code/plugin-collapsible-sections": "^0.42.0",
    "@expressive-code/plugin-line-numbers": "^0.42.0",
    "@iconify-json/bi": "^1.2.7",
    "astro": "^6.3.5",
    "astro-icon": "^1.1.5",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.2",
    "vitest": "^3.2.4"
  }
}

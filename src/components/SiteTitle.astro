---
import Default from '@astrojs/starlight/components/SiteTitle.astro';
import { Icon } from 'astro-icon/components';
import {
  currentVersion,
  detectVersion,
  rootHref,
  stripBase,
  stripLocale,
  versionHref,
} from '../lib/version-routing';

const { lang } = Astro.locals.starlightRoute;
const locale: 'en' | 'th' = lang === 'th' ? 'th' : 'en';

// Resolve the version that the header nav should link into. If the user is
// already inside a version (e.g. /0-1-0-preview/guide/), use that one;
// otherwise fall back to the configured current version.
const { path: stripped } = stripLocale(stripBase(Astro.url.pathname));
const activeVersion = detectVersion(stripped) ?? currentVersion;

interface NavLink {
  label: string;
  thLabel: string;
  /** Path inside the version (omit leading slash). Empty = link to /about for non-versioned. */
  innerPath: string;
  isVersioned: boolean;
}

// Header nav. Labels + targets mirror the footer's link columns so the
// header and footer stay consistent. `isVersioned` items resolve into the
// active version; About is site-wide.
const links: NavLink[] = [
  { label: 'Get started', thLabel: 'เริ่มต้น', innerPath: 'guide/quickstart', isVersioned: true },
  { label: 'Tutorials', thLabel: 'บทเรียน', innerPath: 'tutorials', isVersioned: true },
  { label: 'Technology', thLabel: 'Technology', innerPath: 'technology', isVersioned: true },
  { label: 'Reference', thLabel: 'Reference', innerPath: 'reference', isVersioned: true },
  { label: 'Contributing', thLabel: 'ร่วมพัฒนา', innerPath: 'contributing', isVersioned: true },
  { label: 'About', thLabel: 'เกี่ยวกับ', innerPath: 'about', isVersioned: false },
];

function buildHref(link: NavLink): string {
  return link.isVersioned
    ? versionHref(activeVersion.id, link.innerPath, locale)
    : rootHref(link.innerPath, locale);
}

function isActive(link: NavLink): boolean {
  const target = buildHref(link);
  return Astro.url.pathname === target || Astro.url.pathname.startsWith(target);
}

const menuLabel = locale === 'th' ? 'เมนู' : 'Menu';

// Mobile collapsed-nav trigger label — the active section's name when the
// reader is inside one, otherwise the generic "Menu". Desktop keeps the
// caret-only icon (`.ce-header-menu__current` is hidden there via CSS).
const activeLink = links.find((link) => isActive(link));
const triggerLabel = activeLink
  ? (locale === 'th' ? activeLink.thLabel : activeLink.label)
  : menuLabel;
---

<div class="ce-site-title">
  <Default><slot /></Default>

  <nav class="ce-header-nav" aria-label="Primary">
    {links.map((link) => (
      <a
        href={buildHref(link)}
        class={`ce-header-nav__link${isActive(link) ? ' is-active' : ''}`}
      >
        {locale === 'th' ? link.thLabel : link.label}
      </a>
    ))}

    {/* Priority-nav overflow dropdown. Kept as the LAST child of the nav so
        it sits right after the last visible link. site-ui.js's
        `layoutHeaderNav()` measures the header and moves links that don't
        fit into this caret's panel; the caret shows only when something
        overflowed. Below 50rem the whole nav collapses in here. */}
    <details class="ce-header-menu" aria-label={menuLabel}>
      {/* Trigger. Desktop: caret only (the overflow caret) — the label span
          is hidden via CSS. Mobile: the label shows the active section's
          name, or "Menu" when no nav item is active. */}
      <summary class="ce-header-menu__trigger" aria-haspopup="menu" aria-label={triggerLabel}>
        <span class="ce-header-menu__current">{triggerLabel}</span>
        <Icon name="bi:chevron-down" class="ce-header-menu__chevron" size={16} aria-hidden="true" />
      </summary>
      <ul class="ce-header-menu__panel" role="menu">
        {links.map((link) => (
          <li role="presentation">
            <a
              role="menuitem"
              href={buildHref(link)}
              class={`ce-header-menu__option${isActive(link) ? ' is-active' : ''}`}
            >
              {locale === 'th' ? link.thLabel : link.label}
            </a>
          </li>
        ))}
      </ul>
    </details>
  </nav>
</div>

{/* Mobile menu dropdown JS lives in /public/scripts/site-ui.js — see Head.astro */}

# Keep the Docker build context lean — without this, `COPY . .` would haul
# multi-GB `dist/` + `node_modules/` into the build context and cripple
# build speed. Dependencies are reinstalled fresh inside the image via
# `npm ci`; the site is rebuilt from source.

# Dependencies — reinstalled by `npm ci` in the builder stage.
node_modules

# Build output — regenerated by `npm run build` in the builder stage.
dist
.astro
src/content/.astro

# Caches
.vite
**/.cache

# Docker artefacts that are NOT consumed by the build itself.
# NOTE: `docker/` is intentionally NOT ignored — the runtime stage does
# `COPY docker/nginx.conf ...`, so that directory must stay in the context.
Dockerfile
docker-compose.yml
.dockerignore

# Version control + CI
.git
.github
.gitignore

# Editor / OS noise
.vscode
.idea
*.log
.DS_Store
Thumbs.db

# Local env files — never bake secrets / local config into an image.
.env
.env.*

# Tests — not needed to build the deployable site.
tests
vitest.config.mjs
